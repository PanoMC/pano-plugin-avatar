{
  "branches": [
    {
      "name": "dev",
      "prerelease": true
    },
    "main"
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@PanoMC/semantic-release-pano",
      {
        "file": "build/libs/pano-plugin-avatar-${version}.jar",
        "panoVersion": "1.0.0",
        "configs": [
          {
            "resourceId": "pano-plugin-avatar",
            "panoUrl": "https://api-dev.panomc.com",
            "tokenVar": "PANO_TOKEN"
          },
          {
            "resourceId": "pano-plugin-avatar",
            "panoUrl": "https://api.panomc.com",
            "tokenVar": "PANO_PROD_TOKEN"
          }
        ]
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "build/libs/*.jar",
            "label": false
          },
          {
            "path": "LICENSE",
            "label": false
          }
        ]
      }
    ]
  ],
  "repositoryUrl": "https://github.com/PanoMC/pano-plugin-avatar.git"
}